        "import math\n",
        "\n",
        "def sigmoid(x):\n",
        "    \"\"\"Sigmoid activation function\"\"\"\n",
        "    return 1 / (1 + math.exp(-x))\n",
        "\n",
        "def tanh(x):\n",
        "    \"\"\"Tanh activation function\"\"\"\n",
        "    return math.tanh(x)\n",
        "\n",
        "def lstm_forward():\n",
        "    print(\"=\"*50)\n",
        "    print(\"LSTM Numerical Example Implementation\")\n",
        "    print(\"=\"*50)\n",
        "\n",
        "    # LSTM Parameters (Weights and biases)\n",
        "    W_f = 0.5; W_hf = 0.1; b_f = 0\n",
        "    W_i = 0.6; W_hi = 0.2; b_i = 0\n",
        "    W_c = 0.7; W_hc = 0.3; b_c = 0\n",
        "    W_o = 0.8; W_ho = 0.4; b_o = 0\n",
        "\n",
        "    # Initial States\n",
        "    h = 0.0\n",
        "    C = 0.0\n",
        "\n",
        "    # Input sequence (t=1,2,3,4)\n",
        "    # Note: In the PDF, time step 4 uses 4 as input to predict the value.\n",
        "    X = [1, 2, 3, 4]\n",
        "\n",
        "    for t, x in enumerate(X, start=1):\n",
        "        if t == 4:\n",
        "            print(f\"--- Time Step t = {t}, Predict x_{t} = ? ---\")\n",
        "        else:\n",
        "            print(f\"--- Time Step t = {t}, Input x_{t} = {x} ---\")\n",
        "\n",
        "        # 1. Forget gate\n",
        "        f_val = W_f * x + W_hf * h + b_f\n",
        "        f = sigmoid(f_val)\n",
        "        print(f\"1. Forget Gate (f_{t}):\")\n",
        "        print(f\"   f_{t} = σ({W_f}({x}) + {W_hf}({h:.3f}) + {b_f}) = σ({f_val:.3f}) = {f:.3f}\")\n",
        "\n",
        "        # 2. Input gate\n",
        "        i_val = W_i * x + W_hi * h + b_i\n",
        "        i = sigmoid(i_val)\n",
        "        print(f\"2. Input Gate (i_{t}):\")\n",
        "        print(f\"   i_{t} = σ({W_i}({x}) + {W_hi}({h:.3f}) + {b_i}) = σ({i_val:.3f}) = {i:.3f}\")\n",
        "\n",
        "        # 3. Candidate cell state\n",
        "        C_tilde_val = W_c * x + W_hc * h + b_c\n",
        "        C_tilde = tanh(C_tilde_val)\n",
        "        print(f\"3. Candidate Cell State (C~_{t}):\")\n",
        "        print(f\"   C~_{t} = tanh({W_c}({x}) + {W_hc}({h:.3f}) + {b_c}) = tanh({C_tilde_val:.3f}) = {C_tilde:.3f}\")\n",
        "\n",
        "        # 4. Cell state update\n",
        "        C_new = (f * C) + (i * C_tilde)\n",
        "        print(f\"4. Cell State Update (C_{t}):\")\n",
        "        print(f\"   C_{t} = ({f:.3f} * {C:.3f}) + ({i:.3f} * {C_tilde:.3f}) = {C_new:.3f}\")\n",
        "        C = C_new\n",
        "\n",
        "        # 5. Output gate\n",
        "        o_val = W_o * x + W_ho * h + b_o\n",
        "        o = sigmoid(o_val)\n",
        "        print(f\"5. Output Gate (o_{t}):\")\n",
        "        print(f\"   o_{t} = σ({W_o}({x}) + {W_ho}({h:.3f}) + {b_o}) = σ({o_val:.3f}) = {o:.3f}\")\n",
        "\n",
        "        # 6. Hidden state update\n",
        "        tanh_C = tanh(C)\n",
        "        h_new = o * tanh_C\n",
        "        print(f\"6. Hidden State Update (h_{t}):\")\n",
        "        print(f\"   h_{t} = {o:.3f} * tanh({C:.3f}) = {o:.3f} * {tanh_C:.3f} = {h_new:.3f}\")\n",
        "        h = h_new\n",
        "        print()\n",
        "\n",
        "    # Step 3: Predict the Next Value\n",
        "    print(\"--- Final Prediction ---\")\n",
        "    W_y = 4\n",
        "    b_y = 0\n",
        "    y_hat = (W_y * h) + b_y\n",
        "    print(f\"Linear transformation: y_hat = W_y * h_4 + b_y\")\n",
        "    print(f\"y_hat = {W_y} * {h:.3f} + {b_y} = {y_hat:.3f}\")\n",
        "    print(f\"The LSTM predicts {y_hat:.3f}, which is close to 4, showing that the model has learned the pattern.\")\n",
        "\n",
        "lstm_forward()"
      ]
